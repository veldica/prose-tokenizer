{
  "name": "@veldica/prose-tokenizer",
  "version": "1.1.2",
  "description": "Deterministic, rule-based prose tokenizer for English and Markdown. High-precision splitting for paragraphs, sentences, and words with character-accurate offsets.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./words": {
      "types": "./dist/words.d.ts",
      "import": "./dist/words.js"
    },
    "./sentences": {
      "types": "./dist/sentences.d.ts",
      "import": "./dist/sentences.js"
    },
    "./paragraphs": {
      "types": "./dist/paragraphs.d.ts",
      "import": "./dist/paragraphs.js"
    },
    "./markdown": {
      "types": "./dist/markdown.d.ts",
      "import": "./dist/markdown.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "tokenizer",
    "tokenization",
    "sentence-splitter",
    "sentence-segmentation",
    "text-segmentation",
    "prose",
    "markdown",
    "text-analysis",
    "word-count",
    "paragraph-splitting",
    "editorial-tooling",
    "nlp",
    "deterministic",
    "markdown-tokenizer",
    "rule-based",
    "llm",
    "ai"
  ],
  "license": "MIT",
  "author": {
    "name": "Veldica",
    "email": "opensource@veldica.com",
    "url": "https://veldica.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/veldica/prose-tokenizer.git"
  },
  "bugs": {
    "url": "https://github.com/veldica/prose-tokenizer/issues"
  },
  "homepage": "https://veldica.com/prose-tokenizer",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
  },
  "files": [
    "dist",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "devDependencies": {
    "@types/node": "^22.13.9",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
